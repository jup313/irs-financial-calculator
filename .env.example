# ─── IRS Financial Calculator — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — this example file is safe to commit.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

JWT_EXPIRY=8h
BCRYPT_ROUNDS=12

# First admin account password — set before first launch
DEFAULT_ADMIN_PASSWORD=ChangeMe@First!

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/data/users.db

# ── Web server port (nginx) ───────────────────────────────────────────────────
HTTP_PORT=80

# ── Facebook Graph API (optional) ─────────────────────────────────────────────
# Leave blank to disable Facebook integration
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GROUP_ID=
